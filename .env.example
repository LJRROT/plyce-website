# Production origin for Open Graph / canonical URLs (no trailing slash), e.g. https://plyce.io
VITE_SITE_URL=https://plyce.io

# Optional: https://web3forms.com — use inbox mail@plyce.app when creating the access key.
# If unset, "Request Demo" opens the visitor's mail client with a prefilled message to mail@plyce.app.
VITE_WEB3FORMS_ACCESS_KEY=
