# Production origin for Open Graph / canonical URLs (no trailing slash), e.g. https://plyce.io
VITE_SITE_URL=https://plyce.io

# --- Request Demo → Resend (server-side only, never VITE_) ---
# Kopiere diese Datei nach .env und trage echte Werte ein. .env wird nicht ins Git committed.
# Get API key: https://resend.com/api-keys
# "from" must use a verified domain (or Resend onboarding address for tests).
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL="plyce Website <onboarding@resend.dev>"
# Im Resend-Testmodus nur an die Account-E-Mail; mit verifizierter Domain beliebige Empfänger.
DEMO_REQUEST_TO_EMAIL=ihre-email@beispiel.de

# Optional: full URL if the API is not same-origin (default: /api/send-demo-request).
# VITE_DEMO_REQUEST_API_URL=https://plyce.io/api/send-demo-request
